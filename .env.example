# Postgres connection (matches docker-compose.yml)
DATABASE_URI=postgres://safar:safar@localhost:5432/safar

# Integration test database. By default `npm test` boots a throwaway embedded
# Postgres on this fixed port (see test/global-setup.ts) — no server needed.
# To test against an external/managed Postgres, point this at it and drop the
# globalSetup in vitest.config.ts.
DATABASE_URI_TEST=postgres://postgres:postgres@localhost:54329/safar_test

# Secret used by Payload to sign tokens. Generate a long random string for real deploys.
PAYLOAD_SECRET=dev-only-change-me

# Public base URL of the app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
