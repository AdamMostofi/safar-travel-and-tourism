# Postgres connection (matches docker-compose.yml)
DATABASE_URI=postgres://safar:safar@localhost:5432/safar

# Integration test database. By default `npm test` boots a throwaway embedded
# Postgres on this fixed port (see test/global-setup.ts) — no server needed.
# To test against an external/managed Postgres, point this at it and drop the
# globalSetup in vitest.config.ts.
DATABASE_URI_TEST=postgres://postgres:postgres@localhost:54329/safar_test

# Secret used by Payload to sign tokens. Generate a long random string for real deploys.
PAYLOAD_SECRET=dev-only-change-me

# Public base URL of the app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Vercel Blob object storage. Leave unset for local dev/tests (uploads go to the
# local `media/` folder). Set it in production so CMS + seed uploads persist on
# serverless hosting. Get the value from the Vercel dashboard: Storage → your
# Blob store → `.env` tab (variable name BLOB_READ_WRITE_TOKEN).
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# Google Analytics (all optional — leave unset to disable analytics entirely).
# NEXT_PUBLIC_GA_ID enables GA4 tracking on the public site (the G-XXXX
# measurement ID from GA Admin → Data Streams).
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
#
# The two below power the traffic panel in the CMS dashboard via the GA Data API.
# GA_PROPERTY_ID is the GA4 *numeric* property ID (GA Admin → Property Settings).
# GA_SERVICE_ACCOUNT_KEY is the service-account JSON key, base64-encoded
# (single-line, Vercel-friendly): `base64 -w0 key.json`. The service account must
# be added as a Viewer on the GA property and have the Analytics Data API enabled.
# GA_PROPERTY_ID=123456789
# GA_SERVICE_ACCOUNT_KEY=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Iiwi...
